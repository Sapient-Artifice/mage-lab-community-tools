# Mage Slack — environment variables
# Copy to .env and fill in values, or export these in your shell.

# Slack bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Secret token used to authenticate inbound requests to the Slack bot's HTTP API
SLACK_MAGE_API_TOKEN=your-secret-token-here

# Base URL of the mage ask_assistant API
# Default: http://127.0.0.1:11115
MAGE_API_BASE=http://127.0.0.1:11115

# URL of the ask_assistant endpoint (overrides MAGE_API_BASE for notifications)
# Default: http://127.0.0.1:11115/ask_assistant
MAGE_ASK_ASSISTANT_URL=http://127.0.0.1:11115/ask_assistant
