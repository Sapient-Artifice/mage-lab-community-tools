# Mage Scheduler — environment variables
# Copy to .env and fill in values, or export these in your shell.

# Port the FastAPI server listens on (default: 8012)
MAGE_SCHEDULER_PORT=8012

# Public base URL of the scheduler (used by external tools to reach the API)
MAGE_SCHEDULER_URL=http://127.0.0.1:8012

# Absolute path to the mage_scheduler directory (used by RunMageScheduler.sh if needed)
MAGE_SCHEDULER_HOME=/path/to/mage_scheduler

# Python interpreter to use (default: python3)
MAGE_SCHEDULER_PYTHON=python3

# URL of the ask_assistant endpoint for completion notifications
# Default: http://127.0.0.1:11115/ask_assistant
MAGE_ASK_ASSISTANT_URL=http://127.0.0.1:11115/ask_assistant
